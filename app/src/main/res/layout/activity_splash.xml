<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top accent stripe -->
    <View
        android:id="@+id/accentStripe"
        android:layout_width="56dp"
        android:layout_height="4dp"
        android:background="@color/brand_secondary"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Cab icon with yellow circle background -->
    <TextView
        android:id="@+id/logoIcon"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:gravity="center"
        android:text="🚕"
        android:textSize="40sp"
        android:background="@drawable/bg_circle_yellow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <!-- App name -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Campus Taxi"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:letterSpacing="0.02"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/logoIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- "Pooling" in yellow -->
    <TextView
        android:id="@+id/appNameAccent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pooling"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/brand_secondary"
        android:letterSpacing="0.02"
        app:layout_constraintTop_toBottomOf="@id/appName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tagline"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="10dp"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toBottomOf="@id/appNameAccent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Loading dot at bottom -->
    <ProgressBar
        android:id="@+id/loadingBar"
        style="?android:progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/brand_secondary"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>