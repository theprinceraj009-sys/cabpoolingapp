<?xml version="1.0" encoding="utf-8"?>
<!-- Full Profile Fragment Layout -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Header gradient banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_profile_header">

            <!-- Avatar circle -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">
                
                <TextView
                    android:id="@+id/avatarInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_circle_avatar"/>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileImageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImageView"/>
            </FrameLayout>

            <TextView
                android:id="@+id/profileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/profileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Info Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <!-- Rides Posted -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/ridesPostedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary_light"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_posted"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Rides Joined -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="3dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/ridesJoinedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_accent"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_joined"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Rating/Tier -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tierBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="24sp"/>
                    <TextView
                        android:id="@+id/tierLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/free_tag"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Profile Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_details"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="14dp"/>

                <!-- Roll Number -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                        android:text="🎓" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/roll_number_label" android:textSize="11sp" android:textColor="@color/text_hint"/>
                        <TextView android:id="@+id/rollNumberText" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="14sp"
                            android:textColor="@color/text_primary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/bg_divider"/>

                <!-- Department -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                        android:text="🏢" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/department_label" android:textSize="11sp" android:textColor="@color/text_hint"/>
                        <TextView android:id="@+id/departmentText" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="14sp"
                            android:textColor="@color/text_primary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/bg_divider"/>

                <!-- Campus -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                        android:text="🏫" android:textSize="18sp" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/campus_label" android:textSize="11sp" android:textColor="@color/text_hint"/>
                        <TextView android:id="@+id/campusText" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="14sp"
                            android:textColor="@color/text_primary" android:layout_marginTop="2dp"
                            android:text="@string/cu_chandigarh"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminConsoleBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="ADMIN CONSOLE"
                android:textSize="14sp"
                android:visibility="gone"
                android:backgroundTint="@color/bg_card"
                android:layout_marginBottom="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/brand_accent"
                app:icon="@android:drawable/ic_lock_lock"
                app:iconTint="@color/brand_accent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editProfileBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/edit_profile_btn"
                android:textSize="14sp"
                android:backgroundTint="@color/bg_card"
                android:layout_marginBottom="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/brand_primary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settingsBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/settings_language_btn"
                android:textSize="14sp"
                android:backgroundTint="@color/bg_card"
                android:layout_marginBottom="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/text_secondary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/sign_out_btn"
                android:textSize="14sp"
                android:textColor="@color/status_error"
                android:backgroundTint="@color/bg_card"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/status_error"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
