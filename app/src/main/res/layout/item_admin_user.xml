<?xml version="1.0" encoding="utf-8"?>
<!-- Single admin user card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <TextView
            android:id="@+id/userInitial"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_circle_primary"
            android:layout_marginEnd="12dp"/>

        <!-- Info column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/userName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="6dp"/>

                <!-- Banned badge (visible only when banned) -->
                <TextView
                    android:id="@+id/bannedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BANNED"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_badge_active"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/userEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/reportCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/userDeptText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Ban / Unban toggle -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/banToggleBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Ban"
            android:textSize="11sp"
            android:paddingHorizontal="14dp"
            android:backgroundTint="@color/status_error"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
