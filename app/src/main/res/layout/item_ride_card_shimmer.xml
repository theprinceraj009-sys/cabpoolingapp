<?xml version="1.0" encoding="utf-8"?>
<!-- Ride card item Shimmer Skeleton — Uber/Ola Premium Style -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="2dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Poster avatar + name + status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <!-- Avatar circle skeleton -->
            <View
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_circle_primary"
                android:backgroundTint="@color/bg_input"
                android:layout_marginEnd="12dp"/>

            <!-- Name & Department skeleton -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <View
                    android:layout_width="120dp"
                    android:layout_height="16dp"
                    android:background="@color/bg_input"
                    android:layout_marginBottom="4dp"/>

                <View
                    android:layout_width="80dp"
                    android:layout_height="12dp"
                    android:background="@color/bg_input"/>
            </LinearLayout>

            <!-- Status badge skeleton -->
            <View
                android:layout_width="60dp"
                android:layout_height="24dp"
                android:background="@color/bg_input"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bg_divider"
            android:layout_marginBottom="14dp"/>

        <!-- Route: Source → Destination with indicator dots -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Route indicator column -->
            <LinearLayout
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="3dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/bg_input"/>

                <View
                    android:layout_width="2dp"
                    android:layout_height="24dp"
                    android:background="@color/bg_input"
                    android:layout_marginVertical="2dp"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/bg_input"/>
            </LinearLayout>

            <!-- Source & Destination labels skeleton -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="200dp"
                    android:layout_height="18dp"
                    android:background="@color/bg_input"
                    android:layout_marginBottom="20dp"/>

                <View
                    android:layout_width="180dp"
                    android:layout_height="18dp"
                    android:background="@color/bg_input"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Info chips skeleton: Time | Fare | Seats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@color/bg_input"/>

            <View android:layout_width="4dp" android:layout_height="0dp"/>

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@color/bg_input"/>

            <View android:layout_width="4dp" android:layout_height="0dp"/>

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@color/bg_input"/>
        </LinearLayout>

        <!-- CTA Button skeleton -->
        <View
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bg_input"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
