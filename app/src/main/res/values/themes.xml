<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme — Adaptively switches between Light and Dark -->
    <style name="Base.Theme.CampusTaxiPooling" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Cab Yellow as primary CTA color -->
        <item name="colorPrimary">@color/brand_secondary</item>
        <item name="colorOnPrimary">@color/black</item>
        
        <!-- Adaptive Backgrounds -->
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        
        <!-- Custom UI element tokens -->
        <item name="colorPrimaryContainer">?attr/colorSurfaceVariant</item>
        <item name="colorOnPrimaryContainer">?attr/colorOnSurface</item>
        
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.CampusTaxiPooling" parent="Base.Theme.CampusTaxiPooling" />

    <style name="Theme.CampusTaxiPooling.Splash" parent="Base.Theme.CampusTaxiPooling">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Widget.CampusTaxi.Button.Yellow" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_secondary</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
    </style>
</resources>