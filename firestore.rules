rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 🛡️ Helper Functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Server-side admin check: reads the user's own profile field isAdmin
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // CRITICAL: Block all writes for banned users
    // Uses exists() guard so that brand-new users (no document yet) are not blocked.
    function isNotBanned() {
      return isAuthenticated() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isUserBanned', false) != true
      );
    }

    // ─── 1. Users Collection ────────────────────────────────────────────────────
    match /users/{userId} {
      // Security Audit: Changed 'read' to 'get' to prevent collection-wide scraping/listing.
      // Authenticated users can view specific profiles, but cannot list all users.
      allow get: if isAuthenticated();
      // Owner can create their initial profile once
      allow create: if isOwner(userId);
      // Owner can update, but must NOT be banned. Admins can always toggle ban/admin status.
      allow update: if (isOwner(userId) && isNotBanned()) || isAdmin();
      allow delete: if false;

      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) && isNotBanned();
      }
    }

    // ─── 2. Rides Collection ────────────────────────────────────────────────────
    match /rides/{rideId} {
      allow read: if isAuthenticated();

      // Poster must be authenticated and not banned.
      // Field names match the Java Ride model (totalSeats, totalFare).
      allow create: if isNotBanned()
        && request.resource.data.postedByUid == request.auth.uid
        && request.resource.data.totalSeats is int
        && request.resource.data.totalSeats >= 1
        && request.resource.data.totalFare is number
        && request.resource.data.totalFare >= 0;

      // Only poster (if not banned) or Admin can update metadata or status
      allow update: if (resource.data.postedByUid == request.auth.uid && isNotBanned()) || isAdmin();

      allow delete: if false;

      match /seatRequests/{requestId} {
        allow read: if isAuthenticated();
        // Joiner must not be banned to request seats
        allow create: if isNotBanned()
          && request.resource.data.requesterUid == request.auth.uid;
        
        // Updates (Accept/Deny) allowed for Poster (if not banned) or Admin
        allow update: if (resource.data.requesterUid == request.auth.uid && isNotBanned())
                      || (get(/databases/$(database)/documents/rides/$(rideId)).data.postedByUid == request.auth.uid && isNotBanned())
                      || isAdmin();
        allow delete: if false;
      }
    }

    // ─── 3. Connections & Chats ───────────────────────────────────────────────
    match /connections/{connectionId} {
      allow read: if isAuthenticated()
        && (request.auth.uid in resource.data.participants || 
            request.auth.uid == resource.data.posterUid || 
            request.auth.uid == resource.data.joinerUid ||
            isAdmin());
      
      // Creating a connection requires being a match/participant
      allow create: if isNotBanned()
        && (request.auth.uid == request.resource.data.posterUid || 
            request.auth.uid == request.resource.data.joinerUid);
      
      allow update: if isNotBanned()
        && request.auth.uid in resource.data.participants;
      
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.participants;

        // Messaging strictly forbidden for banned users
        allow create: if isNotBanned()
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.participants
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        allow update, delete: if false;
      }
    }

    // ─── 4. Reports Collection ──────────────────────────────────────────────────
    match /reports/{reportId} {
      // Any non-banned user can report another user
      allow create: if isNotBanned()
        && request.resource.data.reporterUid == request.auth.uid;

      // Only admins manage the report resolution flow
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ─── 5. Audit & ERP Traceability ──────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions Only
    }
  }
}
