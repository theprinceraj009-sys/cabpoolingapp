rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 1. Users Collection
    match /users/{userId} {
      // Anyone logged in can read public profiles
      allow read: if isAuthenticated();
      // Users can only create or update their own profile
      allow create, update: if isOwner(userId);
      // No one can dynamically delete their user doc from the client
      allow delete: if false;
      
      // User Notifications Sub-collection
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Rides Collection
    match /rides/{rideId} {
      // Anyone logged in can browse the active ride feed
      allow read: if isAuthenticated();
      
      // Ride creation demands the postedByUid matches the requester's identity
      allow create: if isAuthenticated() && request.resource.data.postedByUid == request.auth.uid;
      
      // Updates allowed only if the user owns the ride
      allow update: if isAuthenticated() && resource.data.postedByUid == request.auth.uid;
      
      // Soft deletion natively handles logical deletes
      allow delete: if false;

      // Seat Requests Sub-collection
      match /seatRequests/{requestId} {
        // The ride poster OR the person making the request can view it
        allow read: if isAuthenticated();
        
        // Anyone can create a request, but requesterUid must be their own
        allow create: if isAuthenticated() && request.resource.data.requesterUid == request.auth.uid;
        
        // Requester can update (cancel), Poster can update (accept/reject)
        allow update: if isAuthenticated() 
          && (resource.data.requesterUid == request.auth.uid 
              || get(/databases/$(database)/documents/rides/$(rideId)).data.postedByUid == request.auth.uid);
              
        allow delete: if false;
      }
    }

    // 3. Connections & Chats Collection
    match /connections/{connectionId} {
      // Users can ONLY view the connection metadata if they are inside the participants array
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Connected users are formed via transaction in RideRepository
      allow create: if isAuthenticated();
      // No ad-hoc updates from either client to connections metadata allowed immediately, 
      // preventing chat state hacking
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // Messages Sub-collection
      match /messages/{messageId} {
        // Can only read and write messages if they are participating in the connection
        allow read: if isAuthenticated() 
           && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.participants;
           
        allow create: if isAuthenticated() 
           && request.resource.data.senderUid == request.auth.uid
           && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.participants;
           
        allow update, delete: if false;
      }
    }

    // 4. Reports Collection
    match /reports/{reportId} {
      // Anyone can submit a report, but only admins (via cloud functions/dashboard) can read it
      allow create: if isAuthenticated() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
